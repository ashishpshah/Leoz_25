@model ResponseModel<Vendor>

@{
	Layout = null;
}

<div class="col-md-12" style="margin-bottom: -21px;">
	<div class="card card-info">

		<div class="card-header">
			<h3 class="card-title">@(Model.Obj != null && Model.Obj.Id > 0 ? "Edit" : "Create") Vendor</h3>
			<input type="text" class="form-control d-none" id="Id" name="Id" value="@(Model.Obj != null && Model.Obj.Id > 0 ? Model.Obj.Id.ToString() : "")">
			<input type="text" class="form-control d-none" id="UserId" name="UserId" value="@(Model.Obj != null && Model.Obj.UserId > 0 ? Model.Obj.UserId.ToString() : "")">
		</div>

        <div class="card-body form-horizontal">

            <!-- Credential Details -->
            <div class="panel-divider mb-3">
                <span>Credential Details</span>

                <div class="row g-3">

                    <!-- Username -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="form-group row align-items-center">
                            <label class="col-12 col-sm-4 col-form-label">User Name<span style="color:red">*</span></label>
                            <div class="col-12 col-sm-8">
                                <input type="text" class="form-control form-control-sm"
                                       id="UserName" name="UserName"
                                       value="@Model.Obj.UserName">
                            </div>
                        </div>
                    </div>

                    <!-- Password / Reset -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="form-group row align-items-center">

                            @if (Model.Obj != null && Model.Obj.Id > 0)
                            {
                                <label class="col-12 col-sm-4 col-form-label">Password Reset</label>
                                <div class="col-12 col-sm-8 align-items-center">
                                    <div class="form-check form-switch">
                                        <input type="checkbox" class="form-check-input"
                                               id="switch_Password_Reset"
                                               name="IsPassword_Reset"
                                               onchange="fnChange_Switch(this, 'label_Switch_Password_Reset')">
                                        <label class="form-check-label"
                                               id="label_Switch_Password_Reset"
                                               data-true="Yes" data-false="No">No</label>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <label class="col-12 col-sm-4 col-form-label">Password<span style="color:red">*</span></label>
                                <div class="col-12 col-sm-8 align-items-center">
                                    <div class="input-group input-group-sm">
                                        <input type="password" id="Password" name="Password"
                                               class="form-control" placeholder="********">
                                        <span class="input-group-text" data-password="true">
                                            <span class="password-eye"></span>
                                        </span>
                                    </div>
                                </div>
                            }

                        </div>
                    </div>

                    <!-- Status -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="form-group row align-items-center">
                            <label class="col-12 col-sm-4 col-form-label">Status</label>
                            <div class="col-12 col-sm-8">
                                <div class="form-check form-check-inline form-control border-0 my-0 py-0">
                                    <input type="checkbox" class="form-check-input" id="switch_Status"
                                           name="IsActive" @((Model.Obj != null && Model.Obj.IsActive == true) || Model.Obj.Id == 0 ? "checked" : "")
                                           onchange="fnChange_Switch(this, 'label_Switch_Status')">
                                    <label class="form-check-label" for="switch_Status" id="label_Switch_Status" data-true="Active" data-false="Inactive">
                                        @((Model.Obj != null && Model.Obj.IsActive == true) || Model.Obj.Id == 0 ? "Active" : "Inactive")
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Personal Details -->
            <div class="panel-divider">
                <span>Personal Details</span>

                <div class="row g-3">

                    <!-- Firstname -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="form-group row align-items-center">
                            <label class="col-12 col-sm-4 col-form-label">First Name<span style="color:red">*</span></label>
                            <div class="col-12 col-sm-8">
                                <input type="text" class="form-control form-control-sm"
                                       id="FirstName" name="FirstName"
                                       value="@Model.Obj.FirstName">
                            </div>
                        </div>
                    </div>

                    <!-- Middlename -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="form-group row align-items-center">
                            <label class="col-12 col-sm-4 col-form-label">Middle Name</label>
                            <div class="col-12 col-sm-8">
                                <input type="text" class="form-control form-control-sm"
                                       id="MiddleName" name="MiddleName"
                                       value="@Model.Obj.MiddleName">
                            </div>
                        </div>
                    </div>

                    <!-- Lastname -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="form-group row align-items-center">
                            <label class="col-12 col-sm-4 col-form-label">Last Name<span style="color:red">*</span></label>
                            <div class="col-12 col-sm-8">
                                <input type="text" class="form-control form-control-sm"
                                       id="LastName" name="LastName"
                                       value="@Model.Obj.LastName">
                            </div>
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="form-group row align-items-center">
                            <label class="col-12 col-sm-4 col-form-label text-sm-end d-flex align-items-center">Email</label>
                            <div class="col-12 col-sm-8">
                                <input type="text" class="form-control form-control-sm"
                                       id="Email" name="Email"
                                       value="@Model.Obj.Email">
                            </div>
                        </div>
                    </div>

                    <!-- Contact -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="form-group row align-items-center">
                            <label class="col-12 col-sm-4 col-form-label text-sm-end d-flex align-items-center">Contact No.</label>
                            <div class="col-12 col-sm-8">
                                <input type="text" class="form-control form-control-sm isNumberKey"
                                       id="ContactNo" name="ContactNo"
                                       value="@Model.Obj.ContactNo">
                            </div>
                        </div>
                    </div>

                    <!-- Alternate -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="form-group row align-items-center">
                            <label class="col-12 col-sm-4 col-form-label text-sm-end d-flex align-items-center">Alternate Contact</label>
                            <div class="col-12 col-sm-8">
                                <input type="text" class="form-control form-control-sm isNumberKey"
                                       id="ContactNo_Alternate" name="ContactNo_Alternate"
                                       value="@Model.Obj.ContactNo_Alternate">
                            </div>
                        </div>
                    </div>

                    <!-- Logo -->
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="form-group row align-items-center">
                            <label class="col-12 col-sm-4 col-form-label text-sm-end d-flex align-items-center">Logo</label>
                            <div class="col-12 col-sm-8">
                                <input type="file" class="form-control form-control-sm"
                                       id="file1"
                                       accept="image/png, image/gif, image/jpeg">
                            </div>
                        </div>
                    </div>

                    <!-- Preview -->
                    <div class="col-12 col-md-6 col-lg-4 d-flex align-items-center">
                        @{
                            string base64String = "http://www.washaweb.com/tutoriaux/fileupload/imgs/image-temp-220.png";
                            try
                            {
                                if (Model.Obj != null && Model.Obj.Logo != null && Model.Obj.Logo.Length > 0)
                                {
                                    base64String = Convert.ToBase64String(Model.Obj.Logo);
                                    base64String = "data:image/png;base64," + base64String;
                                }
                            }
                            catch { }
                        }

                        <img class="img-thumbnail" width="140" src="@base64String" />
                    </div>

                </div>
            </div>

        </div>

		<div class="card-footer">			
				<div class="col-sm-12 text-center">
					<button type="submit" class="btn btn-success btnSubmit">Save</button>
					@*<button type="button" class="btn btn-danger">Cancel</button>*@
					<a href="@Url.Action("Index","Vendor", new {  area = "Admin" })" class="btn btn-danger">Cancel</a>
				
				</div>
	</div>
</div>
</div>

@section Scripts {
	<script type="text/javascript">
		$(document).ready(function () {

		});
	</script>
}
