@model ResponseModel<Customer>

@{
	Layout = null;
}

<div class="col-md-12" style="margin-bottom: -21px;">
	<div class="card card-info">

		<div class="card-header">
			@if (Model.Obj != null && Model.Obj.Id > 0 && Model.Data1 != null && ((bool)Model.Data1 == true))
			{
				<h3 class="card-title">Project Assign</h3>
			}
			else
			{
				<h3 class="card-title">@(Model.Obj != null && Model.Obj.Id > 0 ? "Edit" : "Create") Customer</h3>
			}
			<input type="text" class="form-control d-none" id="Id" name="Id" value="@(Model.Obj != null && Model.Obj.Id > 0 ? Model.Obj.Id.ToString() : "")">
			<input type="text" class="form-control d-none" id="UserId" name="UserId" value="@(Model.Obj != null && Model.Obj.UserId > 0 ? Model.Obj.UserId.ToString() : "")">
		</div>

		<div class="card-body form-horizontal">

			@if (Model.Obj != null && Model.Obj.Id > 0 && Model.Data1 != null && ((bool)Model.Data1 == true))
			{
				<input type="text" class="form-control d-none" id="ProjectMap" name="ProjectMap" value="true">

				<div class="form-group row d-flex align-items-center">
					<div class="col-sm-4" style="margin: 0rem !important;">
						<div class="row">
							<label class="col-sm-3 col-form-label text-md-end">Customer</label>
							<div class="col-sm-9">
								<input type="text" data-altType="text" class="form-control form-control-sm" value="@Model.Obj.Fullname" autocomplete="off" readonly>
							</div>
						</div>
					</div>
					<div class="col-sm-8" style="margin: 0rem !important;">
						<div class="form-group row d-flex align-items-center">
							<label for="ddlProjectIds" class="col-sm-3 col-form-label text-md-end">Project(s)</label>
							<div class="col-sm-9">
								<select id="ddlProjectIds" name="ProjectIds" class="form-control form-control-sm select2_multiple" data-selected="@Model.Obj.ProjectIds">
									@* <option value="0">-- Select --</option> *@
									@if (Model.SelectListItems != null)
									{
										foreach (var item in Model.SelectListItems)
										{
											<option value="@item.Value">@item.Text</option>
										}
									}
								</select>
							</div>
						</div>
					</div>
				</div>
			}
			else
			{

				<div class="panel-divider">
					<span>Credential Details</span>
					<div class="row no-gutters">
						<div class="col-sm-4" style="margin: 0rem !important;">
							<div class="form-group row d-flex align-items-center">
								<label for="UserName" class="col-sm-3 col-form-label text-md-end">Username<span style="color:red">*</span></label>
								<div class="col-sm-6">
									<input type="text" class="form-control form-control-sm" id="UserName" name="UserName" value="@Model.Obj.UserName" autocomplete="off">
								</div>

							</div>
						</div>
						<div class="col-sm-4" style="margin: 0rem !important;">
							<div class="form-group row d-flex align-items-center">
								@if (Model.Obj != null && Model.Obj.Id > 0)
								{
									<label for="IsPassword_Reset" class="col-sm-3 col-form-label text-md-end">Password Reset</label>
									<div class="col-sm-6">
										<div class="form-check form-check-inline form-control border-0 my-0 py-0">
											<input type="checkbox" class="form-check-input" id="switch_Password_Reset"
												   name="IsPassword_Reset" onchange="fnChange_Switch(this, 'label_Switch_Password_Reset')">
											<label class="form-check-label" for="switch_Password_Reset" id="label_Switch_Password_Reset" data-true="Yes" data-false="No">No</label>
										</div>
									</div>
								}
								else
								{
									<label for="Password" class="col-sm-3 col-form-label text-md-end">Password<span style="color:red">*</span></label>
									<div class=" col-sm-6">
										<div class="input-group input-group-merge">
											<input type="password" id="Password" name="Password" class="form-control form-control-sm" placeholder="********" autocomplete="off">
											<div class="input-group-text input-group-text-sm" data-password="true">
												<span class="password-eye"></span>
											</div>
										</div>
									</div>
								}

							</div>

						</div>
						<div class="col-sm-4" style="margin: 0rem !important;">
							<div class="form-group row d-flex align-items-center" style="margin-bottom:20px">
								<label for="IsActive" class="col-sm-3 col-form-label text-md-end">Status</label>
								<div class="col-sm-6">
									<div class="form-check form-check-inline form-control border-0 my-0 py-0">
										<input type="checkbox" class="form-check-input" id="switch_Status"
											   name="IsActive" @((Model.Obj != null && Model.Obj.IsActive == true) || Model.Obj.Id == 0 ? "checked" : "")
											   onchange="fnChange_Switch(this, 'label_Switch_Status')">
										<label class="form-check-label" for="switch_Status" id="label_Switch_Status" data-true="Active" data-false="Inactive">
											@((Model.Obj != null && Model.Obj.IsActive == true) || Model.Obj.Id == 0 ? "Active" : "Inactive")
										</label>
									</div>
								</div>
							</div>
						</div>

					</div>
				</div>
				<div class="panel-divider">
					<span>Personal Details</span>
					<div class="row no-gutters">
						<div class="col-sm-4" style="margin: 0rem !important;">
							<div class="form-group row d-flex align-items-center">
								<label for="FirstName" class="col-sm-3 col-form-label text-md-end">Firstname<span style="color:red">*</span></label>
								<div class="col-sm-9">
									<input type="text" data-altType="text" class="form-control form-control-sm" id="FirstName" name="FirstName" value="@Model.Obj.FirstName" autocomplete="off">
								</div>
							</div>
						</div>
						<div class="col-sm-4" style="margin: 0rem !important;">
							<div class="form-group row d-flex align-items-center">
								<label for="MiddleName" class="col-sm-3 col-form-label text-md-end">Middlename<span style="color:red">*</span></label>
								<div class="col-sm-9">
									<input type="text" data-altType="text" class="form-control form-control-sm" id="MiddleName" name="MiddleName" value="@Model.Obj.MiddleName" autocomplete="off">
								</div>
							</div>
						</div>
						<div class="col-sm-4" style="margin: 0rem !important;">
							<div class="form-group row d-flex align-items-center">
								<label for="LastName" class="col-sm-3 col-form-label text-md-end">Lastname<span style="color:red">*</span></label>
								<div class="col-sm-9">
									<input type="text" data-altType="text" class="form-control form-control-sm" id="LastName" name="LastName" value="@Model.Obj.LastName" autocomplete="off">
								</div>
							</div>
						</div>
					</div>
					<div class="row no-gutters">
						<div class="col-sm-4" style="margin: 0rem !important;">
							<div class="form-group row d-flex align-items-center">
								<label for="Email" class="col-sm-3 col-form-label text-md-end">Email<span style="color:red">*</span></label>
								<div class="col-sm-9">
									<input type="text" data-altType="text" class="form-control form-control-sm" id="Email" name="Email" value="@Model.Obj.Email" autocomplete="off">
								</div>
							</div>
						</div>
						<div class="col-sm-4" style="margin: 0rem !important;">
							<div class="form-group row d-flex align-items-center">
								<label for="ContactNo" class="col-sm-3 col-form-label text-md-end">Contact No.<span style="color:red">*</span></label>
								<div class="col-sm-9">
									<input type="text"
										   class="form-control form-control-sm"
										   id="ContactNo"
										   name="ContactNo"
										   value="@Model.Obj.ContactNo"
										   maxlength="10"
										   pattern="[0-9]{10}"
										   inputmode="numeric"
										   autocomplete="off"
										   oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0,10);">
								</div>
							</div>
						</div>
					</div>
					<div class="row no-gutters">
						<div class="col-sm-4" style="margin: 0rem !important;">
							<div class="form-group row d-flex align-items-center">
								<label for="Contact_PersonName" class="col-sm-3 col-form-label text-md-end">Contact Person Name </label>
								<div class="col-sm-9">
									<input type="text" data-altType="text" class="form-control form-control-sm" id="Contact_PersonName" name="Contact_PersonName" value="@Model.Obj.Contact_PersonName" autocomplete="off">
								</div>
							</div>
						</div>
						<div class="col-sm-4" style="margin: 0rem !important;">
							<div class="form-group row d-flex align-items-center" style="margin-bottom:20px">
								<label for="Contact_PersonNo" class="col-sm-3 col-form-label text-md-end">Contact Person Contact No.</label>
								<div class="col-sm-9">
									<input type="text"
										   class="form-control form-control-sm"
										   id="Contact_PersonNo"
										   name="Contact_PersonNo"
										   value="@Model.Obj.Contact_PersonNo"
										   maxlength="10"
										   pattern="[0-9]{10}"
										   inputmode="numeric"
										   autocomplete="off"
										   oninput="this.value = this.value.replace(/[^0-9]/g, '').slice(0,10);">
								</div>
							</div>
						</div>
					</div>
				</div>

			}
		</div>

		<div class="card-footer text-center">
			<button type="submit" class="btn btn-success btnSubmit">Save</button>
			<button type="button" class="btn btn-danger" onclick="fnCloseParialView('divformSave', '#table_Common');">Cancel</button>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script type="text/javascript">
		$(document).ready(function () {

		});
	</script>
}
